# Copy to .env and adjust. docker-compose reads these for the backend/digest.
# For pure local (non-Docker) runs, export them in your shell instead.

# Redis — server-side session store (defaults to the Compose service).
REDIS_URL=redis://redis:6379/0

# Credential-encryption backend for Jira tokens at rest.
#   vault (default) -> HashiCorp Vault Transit; the key never leaves Vault.
#   local           -> AES-256-GCM with APP_ENCRYPTION_KEY (no Vault needed).
CRYPTO_BACKEND=vault

# Only used when CRYPTO_BACKEND=local. Master key for AES-256-GCM.
# Generate a strong value, e.g.:  python -c 'import secrets;print(secrets.token_urlsafe(32))'
# WARNING: changing this after tokens are stored makes them undecryptable.
APP_ENCRYPTION_KEY=dev-only-insecure-key-change-me-please

# --- OIDC / hosted IdP login (e.g. Auth0) ---
# Set all three to enable SSO login; leave blank to use email+password.
# Auth0 example: OIDC_ISSUER=https://your-tenant.us.auth0.com
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# Must be registered as an Allowed Callback URL at the IdP:
OIDC_REDIRECT_URI=http://localhost:8000/auth/oidc/callback
# Where to send the browser after a successful login (the frontend):
OIDC_POST_LOGIN_REDIRECT=http://localhost:5173/
# Secret for the short-lived signed cookie holding OAuth state/nonce/PKCE:
OIDC_STATE_SECRET=dev-only-oidc-state-secret-change-me

# --- NHI context → Jira custom-field mapping (optional) ---
# Map NHI context fields to existing Jira custom fields. Unmapped fields fall
# back to the ticket description. Leave blank to keep everything in the
# description (portable default; no Jira setup needed).
# Example:
# NHI_FIELD_MAP={"resource":{"id":"customfield_10042","type":"text"},"category":{"id":"customfield_10043","type":"option"},"environment":{"id":"customfield_10044","type":"text"},"last_activity":{"id":"customfield_10045","type":"date"}}
NHI_FIELD_MAP=

# --- NHI Blog Digest bonus (run with: docker compose --profile digest up) ---
# Provider-agnostic LLM via an OpenAI-compatible endpoint. Defaults to the
# bundled local Ollama (free, no key). To use a free hosted provider instead,
# override these — e.g. Groq:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.1-8b-instant
#   LLM_API_KEY=<your free Groq key>
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=llama3.2:1b
LLM_API_KEY=

# How often the digest runs (seconds) and where to read posts from.
DIGEST_INTERVAL_SECONDS=86400
DIGEST_BLOG_URL=https://oasis.security/blog

# Digest targets are per-user: each user picks their project(s) in the app
# (Report tab → NHI Blog Digest). The worker files under each user's own Jira
# connection. No deployment-level user/project to configure here.
